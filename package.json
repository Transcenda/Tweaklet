{
  "name": "@tweaklet/server",
  "version": "0.0.1",
  "description": "Everyone is a builder now — describe a change for an AI agent, see it instantly in the running app, and ship it as a PR.",
  "license": "MIT",
  "author": "Joseph Chereshnovsky <jchereshnovsky@transcenda.com> (Transcenda)",
  "homepage": "https://github.com/Transcenda/Tweaklet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Transcenda/Tweaklet.git"
  },
  "bugs": {
    "url": "https://github.com/Transcenda/Tweaklet/issues"
  },
  "keywords": [
    "ai-agent",
    "mcp",
    "opencode",
    "developer-tools",
    "self-hosted"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tweaklet": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "web/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "build:all": "npm run build && npm run build:web",
    "prepare": "npm run build:all",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.17.7",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
